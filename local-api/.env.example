# ─── Pipeon Database ───────────────────────────────────────────────────────────
# Connection string do MongoDB exclusivo do Pipeon.
# Todos os dados internos do sistema (logs, agendamentos, usuários, backups,
# configurações) são armazenados neste banco — separado dos bancos dos sistemas-alvo.
#
# Se não definido, usa mongodb://localhost:27017/ com banco "pipeon".
#
PIPEON_MONGO_URL=mongodb://localhost:27017/

# Nome do banco dentro do servidor acima (padrão: pipeon)
# PIPEON_DB_NAME=pipeon

# ─── Microsoft Entra ID (Azure AD) — broker de login (DORMENTE) ──────────────────
# Enquanto estas variáveis estiverem vazias/ausentes, o endpoint POST /api/auth/microsoft
# responde 503 e o login atual (POST /api/auth/login) segue funcionando normalmente.
# Os valores vêm do App registration (tipo SPA) no portal Azure.
# Ver docs/plano-azure-ad.md (Fases 2 e 5).
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
